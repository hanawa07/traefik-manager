# 애플리케이션
APP_SECRET_KEY=변경필요-최소32자-랜덤문자열
APP_ENV=development
APP_PORT=8000

# 관리자 계정 (초기 설정)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=변경필요

# 데이터베이스
DATABASE_URL=sqlite:///./data/traefik_manager.db

# Traefik
TRAEFIK_CONFIG_PATH=/traefik-config/dynamic

# Authentik
AUTHENTIK_URL=http://authentik:9000
AUTHENTIK_TOKEN=변경필요-authentik-api-토큰

# CORS (프론트엔드 주소)
CORS_ORIGINS=http://localhost:3000

# JWT
JWT_SECRET_KEY=변경필요-최소32자-랜덤문자열
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
