# 애플리케이션
APP_SECRET_KEY=변경필요-최소32자-랜덤문자열
APP_ENV=production
LOG_LEVEL=INFO
APP_PORT=8000

# 공개 도메인
FRONTEND_DOMAIN=traefik-manager.example.com
NEXT_PUBLIC_API_URL=/api/v1
BACKEND_UPSTREAM_URL=http://backend:8000

# 관리자 계정 (초기 설정)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# 데이터베이스
DATABASE_URL=sqlite+aiosqlite:///./data/traefik_manager.db

# Traefik
TRAEFIK_CONFIG_PATH=/traefik-config/dynamic
TRAEFIK_API_URL=http://traefik:8080
TRAEFIK_API_TIMEOUT_SECONDS=5
TRAEFIK_TLS_CERT_RESOLVER=letsencrypt
TRAEFIK_DOCKER_CONTAINER_NAME=traefik
TRAEFIK_ACME_STORAGE_PATH=/letsencrypt/acme.json

# Docker (컨테이너 자동 감지)
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_SOCKET_GID=988
DOCKER_API_VERSION=v1.41
DOCKER_API_TIMEOUT_SECONDS=5

# Cloudflare (선택)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_RECORD_TARGET=
CLOUDFLARE_PROXIED=false
CLOUDFLARE_API_TIMEOUT_SECONDS=10

# Authentik
AUTHENTIK_URL=http://authentik:9000
AUTHENTIK_TOKEN=변경필요-authentik-api-토큰

# CORS (프론트엔드 주소)
CORS_ORIGINS=["https://traefik-manager.example.com","http://localhost:3000"]
ALLOWED_HOSTS=["traefik-manager.example.com","traefik-manager-api.example.com","localhost","127.0.0.1"]

# JWT
JWT_SECRET_KEY=변경필요-최소32자-랜덤문자열
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# 로그인 방어
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_FAILURE_WINDOW_MINUTES=15
LOGIN_LOCKOUT_MINUTES=15
LOGIN_SUSPICIOUS_WINDOW_MINUTES=15
LOGIN_SUSPICIOUS_FAILURE_COUNT=5
LOGIN_SUSPICIOUS_USERNAME_COUNT=3
LOGIN_SUSPICIOUS_BLOCK_MINUTES=30
LOGIN_SUSPICIOUS_BLOCK_ESCALATION_ENABLED=false
LOGIN_SUSPICIOUS_BLOCK_ESCALATION_WINDOW_MINUTES=1440
LOGIN_SUSPICIOUS_BLOCK_ESCALATION_MULTIPLIER=2
LOGIN_SUSPICIOUS_BLOCK_MAX_MINUTES=1440
SECURITY_ALERT_WEBHOOK_TIMEOUT_SECONDS=5
SECURITY_ALERT_EMAIL_TIMEOUT_SECONDS=10
CERTIFICATE_ALERT_WARNING_DAYS=30
CERTIFICATE_ALERT_CHECK_INTERVAL_MINUTES=360
TURNSTILE_VERIFY_TIMEOUT_SECONDS=5
